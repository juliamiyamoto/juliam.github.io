<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio — Julia Miyamoto</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Quattrocento+Sans:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <nav class="nav" id="nav">
    <div class="nav__inner">
      <a href="home.html" class="nav__logo">J<span>M</span></a>
      <button class="nav__toggle" id="navToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav__links" id="navLinks">
        <li><a href="home.html" class="nav__link">Home</a></li>
        <li><a href="aboutme.html" class="nav__link">About Me</a></li>
        <li><a href="portfolio.html" class="nav__link active">Portfolio</a></li>
        <li><a href="contact.html" class="nav__link">Contact</a></li>
        <li><a href="contact.html" class="button button--sm">Let's Talk</a></li>
      </ul>
    </div>
  </nav>

  <main class="nav-offset">

    <div class="page-header">
      <div class="container">
        <span class="eyebrow fade-up">My work</span>
        <h1 class="fade-up" style="color: var(--secondary); font-size: var(--h1);">Portfolio</h1>
        <p class="page-header__sub fade-up">Projects, experiments, and creative explorations at the intersection of technology and design.</p>
      </div>
    </div>

    <section style="padding: var(--space-6) 0 var(--space-7);">
      <div class="container">

        <div class="projects__header">
          <h2 class="section-title" style="margin-bottom: 0;">Selected Projects</h2>
          <div class="project-filters" id="filters">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="design">Design</button>
            <button class="filter-btn" data-filter="tech">Technology</button>
            <button class="filter-btn" data-filter="media">Media</button>
          </div>
        </div>

        <!-- COMING SOON STATE -->
        <div class="projects-coming-soon fade-up">
          <div class="coming-soon__inner">
            <div class="coming-soon__icon" aria-hidden="true">🚧</div>
            <span class="eyebrow">Under Construction</span>
            <h3>Projects Coming Soon</h3>
            <p>I'm currently curating my best work to share here. Check back soon — exciting projects are on the way!</p>
            <div class="coming-soon__previews stagger">
              <div class="preview-card fade-up">
                <div class="preview-card__bar"></div>
                <span class="preview-card__label">Design System</span>
              </div>
              <div class="preview-card fade-up">
                <div class="preview-card__bar"></div>
                <span class="preview-card__label">UX Case Study</span>
              </div>
              <div class="preview-card fade-up">
                <div class="preview-card__bar"></div>
                <span class="preview-card__label">Digital Media</span>
              </div>
            </div>
            <a href="contact.html" class="button" style="margin-top: 32px;">Get Notified</a>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container">
        <div class="cta-banner__inner fade-up">
          <div>
            <span class="eyebrow" style="color: var(--accent);">Have a project in mind?</span>
            <h2 style="color: var(--white); margin-bottom: 0;">Let's collaborate.</h2>
          </div>
          <div class="cta-banner__actions">
            <a href="contact.html" class="button" style="background: var(--primary);">Reach Out</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer__inner">
        <a href="home.html" class="footer__logo">J<span>M</span></a>
        <p class="footer__copy">© 2025 Julia Miyamoto. All rights reserved.</p>
        <nav class="footer__links">
          <a href="home.html" class="footer__link">Home</a>
          <a href="aboutme.html" class="footer__link">About</a>
          <a href="portfolio.html" class="footer__link">Portfolio</a>
          <a href="contact.html" class="footer__link">Contact</a>
        </nav>
      </div>
    </div>
  </footer>

  <script src="main.js"></script>
</body>
</html>